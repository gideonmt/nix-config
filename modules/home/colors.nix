# Oxocarbon color palette
{
  # Base backgrounds / surfaces
  base00 = "#161616";  # background
  base01 = "#262626";  # slightly lighter bg (color0)
  base02 = "#393939";  # selection bg, inactive borders (color8)
  base03 = "#525252";  # selection fg bg

  # Text
  base04 = "#dde1e6";  # foreground, color7
  base05 = "#f2f4f8";  # bright foreground, selection fg, color15
  base06 = "#ffffff";  # pure white

  # Accents
  pink    = "#ee5396";  # color5/13, URLs, active borders, tabs
  magenta = "#ff7eb6";  # color1/9, inactive borders
  purple  = "#be95ff";  # lualine accent
  lavender = "#82cfff"; # color3/11
  blue    = "#33b1ff";  # color4/12
  cyan    = "#3ddbd9";  # color6/14
  green   = "#42be65";  # color2/10

  # Semantic aliases (for readability in configs)
  bg        = "#161616";
  bg-subtle = "#262626";
  bg-muted  = "#393939";
  fg        = "#dde1e6";
  fg-bright = "#f2f4f8";
  accent    = "#ee5396";
  accent2   = "#be95ff";
}
